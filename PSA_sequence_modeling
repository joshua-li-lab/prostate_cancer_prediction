def main():
    parse_args_and_update_config()
    configure_tf_runtime()
    set_global_seed(RANDOM_SEED)

    requested_result_root = RESULT_ROOT
    initialize_new_result_root()

    print(f"Requested RESULT_ROOT: {requested_result_root}")
    print(f"Actual new RESULT_ROOT: {RESULT_ROOT}")

    save_json(
        {
            "requested_result_root": requested_result_root,
            "actual_result_root": RESULT_ROOT,
            "created_at": datetime.now().isoformat(),
        },
        os.path.join(RESULT_ROOT, "run_location.json"),
    )

    save_json(environment_snapshot(), os.path.join(RESULT_ROOT, "environment.json"))
    save_json(config_snapshot(), os.path.join(RESULT_ROOT, "run_config_root.json"))
    save_code_snapshot()

    print(f"TensorFlow version: {tf.__version__}")
    print(f"GPU devices: {tf.config.list_physical_devices('GPU')}")
    print(f"DATA_PATH: {DATA_PATH}")
    print(f"RESULT_ROOT: {RESULT_ROOT}")
    print(f"Experiment order: {[TASK_CONFIGS[t]['display_name'] for t in RUN_TASKS]}")
    print(f"IMBALANCE_METHOD: {IMBALANCE_METHOD}")
    print(f"CALIBRATION_METHOD: {CALIBRATION_METHOD}")
    print(f"THRESHOLD_METHOD: {THRESHOLD_METHOD}")
    print(
        f"K-fold split: test_ratio={TEST_RATIO}, n_splits={N_SPLITS} "
        f"=> approx train/val/test = "
        f"{TRAIN_RATIO:.2f}/{VAL_RATIO:.2f}/{TEST_RATIO:.2f}"
    )

    os.makedirs(RESULT_ROOT, exist_ok=True)

    df, data_audit = load_psa_data(DATA_PATH)
    save_json(data_audit, os.path.join(RESULT_ROOT, "data_audit.json"))

    print("\nData Audit:")
    for k, v in data_audit.items():
        print(f"  {k}: {v}")

    min_cache_len = min(NS)
    patient_cache = build_patient_cache(df, min_cache_len=min_cache_len)
    patient_lookup = build_patient_lookup(patient_cache)

    print(f"\nCached patients with >= {min_cache_len} PSA measurements: {len(patient_cache):,}")

    raw_patient_count = int(data_audit["raw_patients"])
    all_results: Dict[str, Any] = {}

    for task in RUN_TASKS:
        if task not in TASK_CONFIGS:
            raise ValueError(f"Unknown task in RUN_TASKS: {task}")

        all_results[task] = run_task_grid(
            patient_cache=patient_cache,
            patient_lookup=patient_lookup,
            raw_patient_count=raw_patient_count,
            task=task,
        )

    save_json(
        all_results,
        os.path.join(RESULT_ROOT, "all_experiment_results.json"),
    )

    print("\nAll requested tasks completed.")
    print(f"Results are under: {RESULT_ROOT}")
    print(
        "\nTo regenerate retained plots later without retraining, run:\n"
        f"    regenerate_all_plots_under_result_root(r'{RESULT_ROOT}')"
    )


if __name__ == "__main__" and AUTO_RUN:
    main()
