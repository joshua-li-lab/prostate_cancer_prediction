# BLOCK 10: PLATT CALIBRATION AND F2 THRESHOLDING
# ============================================================

def clip_prob(p, eps=1e-7):
    return np.clip(np.asarray(p, dtype=np.float64), eps, 1.0 - eps)


def renormalize_proba(p, eps=1e-7):
    p = np.asarray(p, dtype=np.float64)
    p = np.clip(p, eps, 1.0)
    row_sum = p.sum(axis=1, keepdims=True)
    row_sum = np.where(row_sum > 0, row_sum, 1.0)
    return p / row_sum


def fit_and_apply_calibration(p_val_raw, y_val, p_test_raw, method):
    p_val_raw = clip_prob(p_val_raw)
    p_test_raw = clip_prob(p_test_raw)

    if method == "none" or len(np.unique(y_val)) < 2:
        return p_val_raw, p_test_raw, None

    if method != "platt":
        raise ValueError("CALIBRATION_METHOD must be 'platt' or 'none'. Isotonic was removed.")

    logit_val = np.log(p_val_raw / (1.0 - p_val_raw)).reshape(-1, 1)
    logit_test = np.log(p_test_raw / (1.0 - p_test_raw)).reshape(-1, 1)

    lr = LogisticRegression(max_iter=1000)
    lr.fit(logit_val, y_val)

    p_val = lr.predict_proba(logit_val)[:, 1]
    p_test = lr.predict_proba(logit_test)[:, 1]

    return clip_prob(p_val), clip_prob(p_test), lr


def fit_and_apply_multiclass_calibration(
    p_val_raw: np.ndarray,
    y_val: np.ndarray,
    p_test_raw: np.ndarray,
    method: str,
    num_classes: int,
):
    p_val_raw = renormalize_proba(p_val_raw)
    p_test_raw = renormalize_proba(p_test_raw)

    info = {
        "method": method,
        "applied": False,
        "reason": None,
        "validation_classes": sorted([int(x) for x in np.unique(y_val)]),
    }

    if method == "none":
        info["reason"] = "CALIBRATION_METHOD is none."
        return p_val_raw, p_test_raw, None, info

    if method != "platt":
        raise ValueError("CALIBRATION_METHOD must be 'platt' or 'none'. Isotonic was removed.")

    if len(np.unique(y_val)) < 2:
        info["reason"] = "Validation fold has fewer than two classes."
        return p_val_raw, p_test_raw, None, info

    if len(np.unique(y_val)) < num_classes:
        info["reason"] = (
            "Validation fold is missing at least one class; "
            "multiclass Platt calibration skipped for this fold."
        )
        return p_val_raw, p_test_raw, None, info

    x_val = np.log(np.clip(p_val_raw, 1e-7, 1.0))
    x_test = np.log(np.clip(p_test_raw, 1e-7, 1.0))

    lr = LogisticRegression(max_iter=2000, C=1e6, solver="lbfgs")
    lr.fit(x_val, y_val)

    p_val_cal_partial = lr.predict_proba(x_val)
    p_test_cal_partial = lr.predict_proba(x_test)

    p_val_cal = np.zeros((len(y_val), num_classes), dtype=np.float64)
    p_test_cal = np.zeros((len(p_test_raw), num_classes), dtype=np.float64)

    for j, cls in enumerate(lr.classes_):
        p_val_cal[:, int(cls)] = p_val_cal_partial[:, j]
        p_test_cal[:, int(cls)] = p_test_cal_partial[:, j]

    info["applied"] = True
    info["reason"] = "Multinomial Platt calibration applied."

    return renormalize_proba(p_val_cal), renormalize_proba(p_test_cal), lr, info


def choose_threshold(y_val, p_val, method="f2", task=None):
    if len(np.unique(y_val)) < 2:
        return 0.5

    p_val = clip_prob(p_val)

    precision, recall, thresholds = precision_recall_curve(y_val, p_val)
    precision = precision[:-1]
    recall = recall[:-1]

    if len(thresholds) == 0:
        return 0.5

    beta = 2.0
    scores = (1 + beta ** 2) * precision * recall / (
        beta ** 2 * precision + recall + 1e-10
    )
    return float(thresholds[np.argmax(scores)])


def choose_thresholds_ovr(y_val, p_val_proba, method, num_classes):
    thresholds = np.full(num_classes, 0.5, dtype=np.float64)

    for k in range(num_classes):
        y_bin = (y_val == k).astype(int)
        p_k = p_val_proba[:, k]

        if len(np.unique(y_bin)) < 2:
            thresholds[k] = 0.5
        else:
            thresholds[k] = choose_threshold(
                y_val=y_bin,
                p_val=p_k,
                method="f2",
                task="multi_ovr",
            )

    return thresholds


def predict_ovr(p_proba, thresholds):
    p_proba = renormalize_proba(p_proba)
    margins = p_proba - thresholds[None, :]
    return np.argmax(margins, axis=1)


