def read_input_table(data_path: str) -> pd.DataFrame:
    path = Path(data_path).expanduser()

    if not path.exists():
        raise FileNotFoundError(
            f"Input data file not found: {path}. "
            "Place data.xlsx in the repository root or pass --data-path."
        )

    suffix = path.suffix.lower()

    if suffix == ".csv":
        return pd.read_csv(path)

    if suffix == ".xlsx":
        try:
            return pd.read_excel(path, engine="openpyxl")
        except ImportError as e:
            raise ImportError(
                "Reading .xlsx files requires openpyxl. Install with:\n"
                "    pip install openpyxl"
            ) from e

    if suffix == ".xls":
        return pd.read_excel(path)

    raise ValueError(f"Unsupported input extension '{suffix}'. Use .xlsx, .xls, or .csv.")


def coerce_datetime_column_for_publication(series: pd.Series) -> pd.Series:
    return pd.to_datetime(series, errors="coerce")


def load_psa_data(data_path: str) -> Tuple[pd.DataFrame, Dict[str, Any]]:
    raw = read_input_table(data_path)

    required = [PID_COL, TIME_COL, PSA_COL, LABEL_COL]
    missing = [c for c in required if c not in raw.columns]
    if missing:
        raise ValueError(f"Missing required columns: {missing}. Found columns: {list(raw.columns)}")

    raw_patient_count = int(raw[PID_COL].nunique(dropna=True))

    df = raw[required].copy()
    df[TIME_COL] = coerce_datetime_column_for_publication(df[TIME_COL])
    df[PSA_COL] = pd.to_numeric(df[PSA_COL], errors="coerce")
    df[LABEL_COL] = pd.to_numeric(df[LABEL_COL], errors="coerce")

    df = df.dropna(subset=[PID_COL, TIME_COL, PSA_COL, LABEL_COL]).copy()
    df[LABEL_COL] = df[LABEL_COL].astype(int)
    df[LABEL_COL] = df.groupby(PID_COL)[LABEL_COL].transform("max").astype(int)
    df = df.sort_values([PID_COL, TIME_COL]).reset_index(drop=True)

    audit = {
        "source_file": str(Path(data_path).expanduser()),
        "source_extension": Path(data_path).suffix.lower(),
        "raw_rows": int(len(raw)),
        "raw_patients": raw_patient_count,
        "usable_rows": int(len(df)),
        "usable_patients": int(df[PID_COL].nunique()),
        "psa_min": float(df[PSA_COL].min()),
        "psa_median": float(df[PSA_COL].median()),
        "psa_max": float(df[PSA_COL].max()),
        "note": (
            "Highest-daily PSA preprocessing and diagnosis-date temporal filtering "
            "are not used in this version."
        ),
    }
    return df, audit


def build_patient_cache(df: pd.DataFrame, min_cache_len: int) -> List[Dict[str, Any]]:
    sizes = df.groupby(PID_COL).size()
    keep_pids = set(sizes[sizes >= min_cache_len].index)
    df_keep = df[df[PID_COL].isin(keep_pids)].copy()

    cache = []
    grouped = df_keep.groupby(PID_COL, sort=False)

    for pid, grp in tqdm(grouped, desc="Building Patient Cache"):
        grp = grp.sort_values(TIME_COL)
        cache.append({
            "pid": pid,
            "num_psa": int(len(grp)),
            "psa": grp[PSA_COL].to_numpy(dtype=np.float32),
            "times": grp[TIME_COL].to_numpy(dtype="datetime64[ns]"),
            "label": int(grp[LABEL_COL].iloc[0]),
        })

    return cache


def build_patient_lookup(patient_cache: List[Dict[str, Any]]) -> Dict[Any, Dict[str, Any]]:
    return {rec["pid"]: rec for rec in patient_cache}


