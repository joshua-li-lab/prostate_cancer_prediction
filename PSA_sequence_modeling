            ax.plot(xs, h[val_key], label=f"Validation {ylabel}",
                    color=PLOT_PALETTE["primary_dark"], linestyle="--")
            for ep, v in zip(xs, h[val_key]):
                rows.append({
                    "epoch": int(ep),
                    "metric": train_key,
                    "split": "val",
                    "value": float(v),
                })

        ax.set_xlabel("Epoch")
        ax.set_ylabel(ylabel)
