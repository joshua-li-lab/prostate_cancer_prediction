def build_sequence_bank(
    patient_cache,
    round_df,
    n,
    cutoff,
    task,
    patient_lookup: Optional[Dict[Any, Dict[str, Any]]] = None,
):
    eligible_df = round_df[round_df["eligible"]].copy()
    if len(eligible_df) == 0:
        return None

    feature_names = ["psa_capped", "psa_velocity_per_day", "delta_days"]

    X_list, y_list, pid_list, label_list, meta_rows = [], [], [], [], []

    if patient_lookup is None:
        patient_lookup = build_patient_lookup(patient_cache)

    for _, row in eligible_df.iterrows():
        pid = row["patient_id"]
        if pid not in patient_lookup:
            continue

        rec = patient_lookup[pid]
        y = int(row["y"])

        psas_raw = rec["psa"]
        times = rec["times"]
        label = rec["label"]

        input_raw = psas_raw[:n].astype(np.float32)
        input_times = times[:n]

        input_feat = (
            np.minimum(input_raw, PSA_CAP).astype(np.float32)
            if PSA_CAP is not None else input_raw.astype(np.float32)
        )

        if USE_LOG1P_PSA_FEATURE:
            input_feat = np.log1p(input_feat).astype(np.float32)

        deltas = np.zeros(n, dtype=np.float32)
        velocities = np.zeros(n, dtype=np.float32)

        if n > 1:
            d = (input_times[1:n] - input_times[0:n - 1]) / np.timedelta64(1, "D")
            d = d.astype(np.float32)
            deltas[1:] = d
            safe_d = np.where(d > 0, d, 1.0).astype(np.float32)
            v = np.where(
                d > 0,
                (input_feat[1:n] - input_feat[0:n - 1]) / safe_d,
                0.0,
            ).astype(np.float32)
            velocities[1:] = v

        feats = np.stack([input_feat, velocities, deltas], axis=1).astype(np.float32)

        target_time = pd.NaT
        target_psa = np.nan

        if task == "next_psa":
            target_time = pd.to_datetime(times[n])
            target_psa = float(psas_raw[n])

        elif task == "multi":
            future_psa = psas_raw[n:]
            future_times = times[n:]
            exceed_positions = np.where(future_psa >= cutoff)[0]
            if len(exceed_positions) > 0:
                pos = int(exceed_positions[0])
                target_time = pd.to_datetime(future_times[pos])
                target_psa = float(future_psa[pos])

        followup_days_after_input = float((times[-1] - input_times[-1]) / np.timedelta64(1, "D"))
        num_future_psa = int(max(0, len(times) - n))

        target_days_after_input_end = np.nan
        if pd.notna(target_time):
            target_days_after_input_end = float(
                (np.datetime64(target_time) - input_times[-1]) / np.timedelta64(1, "D")
            )

        possible_censoring_never_lt_12m = bool(
            task == "multi" and y == 0 and followup_days_after_input < 365
        )

        X_list.append(feats)
        y_list.append(y)
        pid_list.append(pid)
        label_list.append(label)

        meta_rows.append({
            "patient_id": pid,
            "label": int(label),
            "task_y": int(y),
            "input_start_time": pd.to_datetime(input_times[0]),
            "input_end_time": pd.to_datetime(input_times[-1]),
            "target_time": target_time,
            "target_psa": target_psa,
            "last_input_psa_raw": float(input_raw[-1]),
            "last_input_psa_feature": float(input_feat[-1]),
            "cutoff": float(cutoff),
            "n": int(n),
            "last_observed_time": pd.to_datetime(times[-1]),
            "followup_days_after_input": followup_days_after_input,
            "num_future_psa": num_future_psa,
            "target_days_after_input_end": target_days_after_input_end,
            "possible_censoring_never_lt_12m": possible_censoring_never_lt_12m,
        })

    if len(X_list) == 0:
        return None

    return {
        "X": np.array(X_list, dtype=np.float32),
        "y": np.array(y_list, dtype=np.int32),
        "pids": np.array(pid_list, dtype=object),
        "labels": np.array(label_list, dtype=np.int32),
        "meta": pd.DataFrame(meta_rows),
        "feature_names": feature_names,
    }


def subset_sequence_bank(bank: Dict[str, Any], split_patient_ids):
    if bank is None:
        return None

    split_set = set(np.asarray(split_patient_ids, dtype=object).tolist())
    mask = np.array([pid in split_set for pid in bank["pids"]], dtype=bool)

    if not mask.any():
        return None

    return (
        bank["X"][mask],
        bank["y"][mask],
        bank["pids"][mask],
        bank["labels"][mask],
        bank["meta"].iloc[np.where(mask)[0]].reset_index(drop=True),
        bank["feature_names"],
    )


