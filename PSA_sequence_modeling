def _load_plot_tables(raw_dir: str) -> Dict[str, pd.DataFrame]:
    tables = {}

    for p in Path(raw_dir).glob("*.csv"):
        if p.name == "manifest.csv":
            continue

        try:
            tables[p.stem] = pd.read_csv(p)
        except Exception as e:
            print(f"[warn] Could not read {p}: {e}")

    return tables


def regenerate_plots_for_run(run_dir: str, output_subdir: str = "regenerated_plots") -> None:
    raw_root = Path(run_dir) / "plot_data_raw"

    if not raw_root.exists():
        print(f"No plot_data_raw folder found under: {run_dir}")
        return

    for raw_dir in raw_root.iterdir():
        if not raw_dir.is_dir():
            continue

        meta_path = raw_dir / "metadata.json"
        if not meta_path.exists():
            continue

        with open(meta_path, "r") as f:
            meta = json.load(f)

        task = meta["task"]
        n = int(meta["n"])
        cutoff = float(meta["cutoff"])
        class_names = meta["class_names"]
        out_dir = Path(run_dir) / output_subdir / raw_dir.name
        out_dir.mkdir(parents=True, exist_ok=True)

        tables = _load_plot_tables(str(raw_dir))

        if "learning_dynamics_kfold" in tables:
            plot_learning_dynamics_from_df(
                tables["learning_dynamics_kfold"],
                str(out_dir / "learning_dynamics_kfold.png"),
                make_plot_title(task, n, cutoff, "K-Fold Learning Dynamics"),
            )

        if "confusion_matrix" in tables:
            plot_confusion_from_long_df(
                tables["confusion_matrix"],
                str(out_dir / "confusion_matrix.png"),
                class_names,
                make_plot_title(task, n, cutoff, "Confusion Matrix"),
            )

        if "roc" in tables:
            plot_roc_from_df(
                tables["roc"],
                str(out_dir / "roc_curve.png"),
                make_plot_title(task, n, cutoff, "ROC Curve"),
            )

        if "calibration" in tables:
            plot_calibration_from_df(
                tables["calibration"],
                str(out_dir / "calibration_plot.png"),
                make_plot_title(task, n, cutoff, "Calibration Plot"),
            )

        for key, df in tables.items():
            if key.startswith("roc_class"):
                cname = str(df["class_name"].iloc[0]) if "class_name" in df.columns and len(df) else None
                plot_roc_from_df(
                    df,
                    str(out_dir / f"{key}.png"),
                    make_plot_title(task, n, cutoff, "ROC Curve", class_name=cname),
                )

        if "calibration_bins_all_classes" in tables:
            for cls_idx, sub in tables["calibration_bins_all_classes"].groupby("class_index"):
                cname = str(sub["class_name"].iloc[0])
                plot_calibration_from_df(
                    sub,
                    str(out_dir / f"calibration_class{int(cls_idx)}.png"),
                    make_plot_title(task, n, cutoff, "Calibration Plot", class_name=cname),
                )

        if "attention_examples" in tables:
            plot_attention_examples_from_df(
                tables["attention_examples"],
                str(out_dir / "attention_examples.png"),
                make_plot_title(task, n, cutoff, "Attention Heatmap Examples"),
            )

        if "attention_summary_by_true_class" in tables:
            plot_attention_summary_df(
