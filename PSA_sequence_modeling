def _sanitize_name(name: Any) -> str:
    s = re.sub(r"[^A-Za-z0-9_.-]+", "_", str(name)).strip("_")
    return s[:120] if s else "unnamed"


def _class_col_name(name: str) -> str:
    return _sanitize_name(name).replace(".", "_").replace("-", "_")


def _unique_sheet_name(base: str, used: set) -> str:
    base = str(base)[:31] or "sheet"
    sheet = base
    k = 1

    while sheet in used:
        suffix = f"_{k}"
        sheet = base[:31 - len(suffix)] + suffix
        k += 1

    used.add(sheet)
    return sheet


def save_plot_data_xlsx(plot_data, save_path):
    if not SAVE_PLOT_DATA_EXCEL:
        return

    try:
        with pd.ExcelWriter(save_path, engine="openpyxl") as writer:
            used = set()

            for name, df in plot_data.items():
                if df is None or len(df) == 0:
                    continue

                if not isinstance(df, pd.DataFrame):
                    df = pd.DataFrame(df)

                safe_name = _sanitize_name(name)

                if len(df) <= EXCEL_MAX_ROWS or not EXCEL_CHUNK_LONG_TABLES:
                    sheet = _unique_sheet_name(safe_name[:31], used)
                    df.iloc[:EXCEL_MAX_ROWS].to_excel(writer, sheet_name=sheet, index=False)
                else:
                    n_chunks = int(math.ceil(len(df) / EXCEL_MAX_ROWS))
                    for c in range(n_chunks):
                        start = c * EXCEL_MAX_ROWS
                        end = min((c + 1) * EXCEL_MAX_ROWS, len(df))
                        chunk = df.iloc[start:end]
                        suffix = f"_{c + 1}"
                        sheet_base = safe_name[:31 - len(suffix)] + suffix
                        sheet = _unique_sheet_name(sheet_base, used)
                        chunk.to_excel(writer, sheet_name=sheet, index=False)

    except ImportError:
        folder = save_path.replace(".xlsx", "_csv")
        os.makedirs(folder, exist_ok=True)

        for name, df in plot_data.items():
            if df is not None and len(df) > 0:
                pd.DataFrame(df).to_csv(
                    os.path.join(folder, f"{_sanitize_name(name)}.csv"),
                    index=False,
                )


def save_plot_data_bundle(
    plot_data: Dict[str, pd.DataFrame],
    save_dir: str,
    prefix: str,
    arrays: Optional[Dict[str, np.ndarray]] = None,
    metadata: Optional[Dict[str, Any]] = None,
) -> None:
    raw_dir = os.path.join(save_dir, "plot_data_raw", _sanitize_name(prefix))
    os.makedirs(raw_dir, exist_ok=True)

    manifest = []
    excel_data = {}

    for name, df in plot_data.items():
        if df is None:
            continue

        if not isinstance(df, pd.DataFrame):
            try:
                df = pd.DataFrame(df)
            except Exception:
                continue

        if len(df) == 0:
            continue

        safe = _sanitize_name(name)
        csv_path = os.path.join(raw_dir, f"{safe}.csv")
        df.to_csv(csv_path, index=False)

        manifest.append({
            "name": name,
            "file": os.path.basename(csv_path),
            "rows": int(len(df)),
            "columns": int(df.shape[1]),
            "included_in_excel": bool(SAVE_PLOT_DATA_EXCEL),
        })

        excel_data[name] = df

    if arrays:
        clean_arrays = {}

        for k, v in arrays.items():
            if v is None:
                continue
            arr = np.asarray(v)
            if arr.dtype == object:
                continue
            clean_arrays[_sanitize_name(k)] = arr

        if clean_arrays:
            npz_path = os.path.join(raw_dir, "arrays.npz")
            np.savez_compressed(npz_path, **clean_arrays)

            manifest.append({
                "name": "arrays",
                "file": "arrays.npz",
                "rows": None,
                "columns": None,
                "included_in_excel": False,
            })

    pd.DataFrame(manifest).to_csv(
        os.path.join(raw_dir, "manifest.csv"),
        index=False,
    )

    if metadata is not None:
        save_json(metadata, os.path.join(raw_dir, "metadata.json"))

    if excel_data and SAVE_PLOT_DATA_EXCEL:
        save_plot_data_xlsx(
            excel_data,
            os.path.join(save_dir, f"plotdata_{_sanitize_name(prefix)}.xlsx"),
        )


def make_split_assignment_df(test_pids, folds) -> pd.DataFrame:
    rows = []

    for pid in test_pids:
        rows.append({
            "patient_id": pid,
            "fold": np.nan,
            "role": "test",
        })

    for fold_idx, (tr, va) in enumerate(folds):
        for pid in tr:
            rows.append({
                "patient_id": pid,
                "fold": int(fold_idx),
                "role": "train",
            })

        for pid in va:
            rows.append({
                "patient_id": pid,
                "fold": int(fold_idx),
                "role": "val",
            })

    return pd.DataFrame(rows)


