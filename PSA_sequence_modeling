def _safe_div(num, den, undefined=np.nan):
    return float(num / den) if den > 0 else undefined


def binary_clinical_metrics(y_true, y_pred, y_score):
    y_true = np.asarray(y_true).astype(int)
    y_pred = np.asarray(y_pred).astype(int)
    y_score = clip_prob(y_score)

    cm = confusion_matrix(y_true, y_pred, labels=[0, 1])
    tn, fp, fn, tp = cm.ravel()

    sens = _safe_div(tp, tp + fn)
    spec = _safe_div(tn, tn + fp)
    ppv = _safe_div(tp, tp + fp)
    npv = _safe_div(tn, tn + fn)

    if len(np.unique(y_true)) > 1:
        auroc = roc_auc_score(y_true, y_score)
    else:
        auroc = np.nan

    return {
        "accuracy": float(accuracy_score(y_true, y_pred)),
        "sensitivity_recall": sens,
        "specificity": spec,
        "precision_ppv": ppv,
        "npv": npv,
        "f1": float(f1_score(y_true, y_pred, zero_division=0)),
        "auroc": auroc,
        "brier": float(brier_score_loss(y_true, y_score)),
        "tp": int(tp),
        "fp": int(fp),
        "tn": int(tn),
        "fn": int(fn),
        "prevalence": float(np.mean(y_true)),
    }


def boot_clinical_metrics(y_true, y_pred, y_score, n_boot, seed):
    rng = np.random.RandomState(seed)
    n = len(y_true)

    keys = [
        "accuracy",
        "sensitivity_recall",
        "specificity",
        "precision_ppv",
        "npv",
        "f1",
        "auroc",
        "brier",
    ]

    boot = {k: [] for k in keys}

    for _ in range(n_boot):
        idx = rng.randint(0, n, n)
        yt = y_true[idx]
        yp = y_pred[idx]
        ys = y_score[idx]

        if len(np.unique(yt)) < 2:
            continue

        m = binary_clinical_metrics(yt, yp, ys)

        for k in keys:
            v = m[k]
            if isinstance(v, (int, float, np.integer, np.floating)) and np.isfinite(v):
                boot[k].append(float(v))

    out = {}
    for k, values in boot.items():
        if len(values) == 0:
            out[k] = (np.nan, np.nan, np.nan)
        else:
            out[k] = (
                float(np.mean(values)),
                float(np.percentile(values, 2.5)),
                float(np.percentile(values, 97.5)),
            )

    return out


def multiclass_brier_normalized(
    y_true: np.ndarray,
    y_proba: np.ndarray,
    num_classes: int,
) -> float:
    y_true = np.asarray(y_true, dtype=int)
    y_proba = renormalize_proba(y_proba)
    y_onehot = np.eye(num_classes, dtype=np.float64)[y_true]
    return float(np.mean(np.mean((y_onehot - y_proba) ** 2, axis=1)))


def multiclass_clinical_metrics(
    y_true: np.ndarray,
    y_pred: np.ndarray,
    y_proba: np.ndarray,
    num_classes: int,
) -> Dict[str, Any]:
    y_true = np.asarray(y_true, dtype=int)
    y_pred = np.asarray(y_pred, dtype=int)
    y_proba = renormalize_proba(y_proba)

    out: Dict[str, Any] = {}

    out["accuracy"] = float(accuracy_score(y_true, y_pred))
    out["balanced_accuracy"] = float(balanced_accuracy_score(y_true, y_pred))
    out["brier_multiclass_normalized"] = multiclass_brier_normalized(
        y_true,
        y_proba,
        num_classes,
    )

    try:
        out["nll_multiclass"] = float(log_loss(y_true, y_proba, labels=list(range(num_classes))))
    except Exception:
        out["nll_multiclass"] = np.nan

    sens_list, spec_list, ppv_list, npv_list = [], [], [], []
    f1_list, auroc_list, brier_list = [], [], []

    for k in range(num_classes):
        y_bin = (y_true == k).astype(int)
        y_hat_bin = (y_pred == k).astype(int)
        p_k = y_proba[:, k]

        cm_k = confusion_matrix(y_bin, y_hat_bin, labels=[0, 1])
        tn, fp, fn, tp = cm_k.ravel()

        sens = _safe_div(tp, tp + fn)
        spec = _safe_div(tn, tn + fp)
        ppv = _safe_div(tp, tp + fp)
        npv = _safe_div(tn, tn + fn)
        f1_k = float(f1_score(y_bin, y_hat_bin, zero_division=0))

        if len(np.unique(y_bin)) > 1:
            auroc_k = roc_auc_score(y_bin, p_k)
        else:
            auroc_k = np.nan

        brier_k = float(brier_score_loss(y_bin, clip_prob(p_k)))
        prev_k = float(np.mean(y_bin))

        out[f"sensitivity_recall_class{k}"] = sens
        out[f"specificity_class{k}"] = spec
        out[f"precision_ppv_class{k}"] = ppv
        out[f"npv_class{k}"] = npv
        out[f"f1_class{k}"] = f1_k
        out[f"auroc_class{k}"] = auroc_k
        out[f"brier_class{k}"] = brier_k
        out[f"tp_class{k}"] = int(tp)
        out[f"fp_class{k}"] = int(fp)
        out[f"tn_class{k}"] = int(tn)
        out[f"fn_class{k}"] = int(fn)
        out[f"prevalence_class{k}"] = prev_k

        sens_list.append(sens)
        spec_list.append(spec)
        ppv_list.append(ppv)
        npv_list.append(npv)
        f1_list.append(f1_k)
        auroc_list.append(auroc_k)
        brier_list.append(brier_k)

    out["sensitivity_recall_macro"] = float(np.nanmean(sens_list))
    out["specificity_macro"] = float(np.nanmean(spec_list))
    out["precision_ppv_macro"] = float(np.nanmean(ppv_list))
    out["npv_macro"] = float(np.nanmean(npv_list))
    out["f1_macro"] = float(np.nanmean(f1_list))
    out["brier_macro"] = float(np.nanmean(brier_list))

    out["precision_macro"] = float(
        precision_score(y_true, y_pred, average="macro", zero_division=0)
    )
    out["recall_macro"] = float(
        recall_score(y_true, y_pred, average="macro", zero_division=0)
    )

    try:
        y_bin_all = label_binarize(y_true, classes=list(range(num_classes)))
        out["auroc_macro"] = float(
            roc_auc_score(
                y_bin_all,
                y_proba,
                average="macro",
                multi_class="ovr",
            )
        )
    except Exception:
        out["auroc_macro"] = float(np.nanmean(auroc_list))

    return out


def boot_multiclass_clinical_metrics(
    y_true: np.ndarray,
    y_pred: np.ndarray,
    y_proba: np.ndarray,
    num_classes: int,
    n_boot: int,
    seed: int,
) -> Dict[str, Tuple[float, float, float]]:
    rng = np.random.RandomState(seed)
    n = len(y_true)

    sample = multiclass_clinical_metrics(y_true, y_pred, y_proba, num_classes)

    skip_prefixes = ("tp_class", "fp_class", "tn_class", "fn_class")
    keys = [
        k for k, v in sample.items()
        if isinstance(v, (int, float, np.integer, np.floating))
        and not k.startswith(skip_prefixes)
    ]

    boot = {k: [] for k in keys}

    for _ in range(n_boot):
        idx = rng.randint(0, n, n)
        yt = y_true[idx]
        yp = y_pred[idx]
        ys = y_proba[idx]

        if len(np.unique(yt)) < 2:
            continue

        m = multiclass_clinical_metrics(yt, yp, ys, num_classes)

        for k in keys:
            v = m.get(k, np.nan)
            if isinstance(v, (int, float, np.integer, np.floating)) and np.isfinite(v):
                boot[k].append(float(v))

    out = {}
    for k, values in boot.items():
        if len(values) == 0:
            out[k] = (np.nan, np.nan, np.nan)
        else:
            out[k] = (
                float(np.mean(values)),
                float(np.percentile(values, 2.5)),
                float(np.percentile(values, 97.5)),
            )

    return out


def calibration_extras(y_true, y_score, n_bins=10):
    y_true = np.asarray(y_true).astype(int)
    y_score = clip_prob(y_score)

    bins = np.linspace(0, 1, n_bins + 1)
    idx = np.clip(np.digitize(y_score, bins) - 1, 0, n_bins - 1)

    rows = []
    ece = 0.0
    mce = 0.0
    n = len(y_true)

    for b in range(n_bins):
        mask = idx == b
        count = int(mask.sum())

        if count == 0:
            continue

        obs = float(y_true[mask].mean())
        pred = float(y_score[mask].mean())
        gap = abs(obs - pred)

        ece += (count / n) * gap
        mce = max(mce, gap)

        rows.append({
            "bin": b,
            "p_lo": float(bins[b]),
            "p_hi": float(bins[b + 1]),
            "count": count,
            "mean_pred": pred,
            "obs_freq": obs,
            "abs_gap": gap,
        })

    slope = np.nan
    intercept = np.nan

    try:
        if len(np.unique(y_true)) > 1:
            p = clip_prob(y_score)
            logit = np.log(p / (1 - p))
            lr = LogisticRegression(max_iter=1000)
            lr.fit(logit.reshape(-1, 1), y_true)
            slope = float(lr.coef_[0, 0])
            intercept = float(lr.intercept_[0])
    except Exception:
        pass

    return (
        {
            "ece": float(ece),
            "mce": float(mce),
            "calibration_slope": slope,
            "calibration_intercept": intercept,
        },
        pd.DataFrame(rows),
    )


