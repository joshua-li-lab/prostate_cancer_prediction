def plot_learning_dynamics_from_df(dyn_df: pd.DataFrame, save_path: str, title: str):
    if dyn_df is None or len(dyn_df) == 0:
        return

    metric_label = {
        "loss": "Loss",
        "accuracy": "Accuracy",
        "auc": "AUROC",
    }

    metrics = [m for m in ["loss", "accuracy", "auc"] if m in set(dyn_df["metric"].astype(str))]
    if not metrics:
        return

    fig, axes = plt.subplots(
        1,
        len(metrics),
        figsize=(5.2 * len(metrics), 4.3),
        constrained_layout=True,
    )
    axes = _prepare_axes_array(axes)

    for ax, metric in zip(axes, metrics):
        sub = dyn_df[dyn_df["metric"] == metric].copy()

        for fold_i in sorted(sub["fold"].dropna().unique()):
            sf = sub[sub["fold"] == fold_i]
            for split, ls, alpha in [("train", "-", 0.35), ("val", "--", 0.75)]:
                ss = sf[sf["split"] == split]
                if len(ss) == 0:
                    continue
                ax.plot(
                    ss["epoch"],
                    ss["value"],
                    linestyle=ls,
                    alpha=alpha,
                    linewidth=1.1,
                    label=f"Fold {int(fold_i)} {split.capitalize()}" if int(fold_i) < 4 else None,
                )

        val = sub[sub["split"] == "val"].copy()
        if len(val) > 0:
            grouped = val.groupby("epoch")["value"]
            mean_v = grouped.mean()
            std_v = grouped.std().fillna(0)
            xs = mean_v.index.to_numpy()
            ax.plot(xs, mean_v.to_numpy(), color="black", linewidth=2.2, label="Mean Validation")
            ax.fill_between(
                xs,
                (mean_v - std_v).to_numpy(),
                (mean_v + std_v).to_numpy(),
                color="black",
                alpha=0.12,
                label="±1 SD",
            )

        ax.set_xlabel("Epoch")
        ax.set_ylabel(metric_label.get(metric, metric.capitalize()))
        ax.grid(alpha=0.3)
        handles, labels = ax.get_legend_handles_labels()
