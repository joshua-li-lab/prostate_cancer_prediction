def run_task_grid(
    patient_cache,
    patient_lookup,
    raw_patient_count,
    task,
):
    cfg = TASK_CONFIGS[task]
    exp_name = cfg["exp_name"]
    num_classes = cfg["num_classes"]
    class_names = cfg["class_names"]

    exp_dir = os.path.join(RESULT_ROOT, exp_name)
    os.makedirs(exp_dir, exist_ok=True)

    save_json(config_snapshot(), os.path.join(exp_dir, "run_config.json"))

    results = []
    grid = [(n, cutoff) for n in NS for cutoff in CUTOFFS]

    t0 = time.time()

    for n, cutoff in tqdm(grid, desc=f"{task_display_name(task)} Grid", total=len(grid)):
        result = run_experiment(
            patient_cache=patient_cache,
            patient_lookup=patient_lookup,
            raw_patient_count=raw_patient_count,
            n=n,
            cutoff=float(cutoff),
            task=task,
            exp_dir=exp_dir,
            num_classes=num_classes,
            class_names=class_names,
        )

        if result is not None:
            results.append(result)

    save_json(results, os.path.join(exp_dir, f"all_results_{task}.json"))

    master_path = os.path.join(exp_dir, f"metrics_{exp_name}.xlsx")
    summary = write_master_workbook(
        results=results,
        out_xlsx=master_path,
        num_classes=num_classes,
    )

    summary.to_csv(
        os.path.join(exp_dir, f"summary_{exp_name}.csv"),
        index=False,
    )

    print(f"\n{task_display_name(task)} finished in {time.time() - t0:.1f} seconds.")
    print(f"Saved to: {exp_dir}")
    print(f"Master workbook: {master_path}")

    return results


