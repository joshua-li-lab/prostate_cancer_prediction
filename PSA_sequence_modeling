def ordinal(n: int) -> str:
    if 10 <= n % 100 <= 20:
        suffix = "th"
    else:
        suffix = {1: "st", 2: "nd", 3: "rd"}.get(n % 10, "th")
    return f"{n}{suffix}"


def min_required_for_task(task: str, n: int) -> int:
    if task == "cancer":
        return n
    return n + 1


def compute_round_patient_table(
    patient_cache: List[Dict[str, Any]],
    n: int,
    cutoff: float,
    task: str,
) -> pd.DataFrame:
    min_required = min_required_for_task(task, n)
    rows = []

    for rec in patient_cache:
        if rec["num_psa"] < min_required:
            continue

        psas = rec["psa"]
        times = rec["times"]
        pid = rec["pid"]
        label = rec["label"]

        eligible = bool(np.all(psas[:n] < cutoff))
        y = -1

        if eligible:
            if task == "next_psa":
                y = int(psas[n] >= cutoff)

            elif task == "cancer":
                y = int(label)

            elif task == "multi":
                future_psa = psas[n:]
                future_times = times[n:]
                exceed_positions = np.where(future_psa >= cutoff)[0]

                if len(exceed_positions) == 0:
                    y = 0
                else:
                    first_pos = int(exceed_positions[0])
                    input_end_time = times[n - 1]
                    exceed_time = future_times[first_pos]
                    days_to_exceed = (exceed_time - input_end_time) / np.timedelta64(1, "D")
                    y = 1 if days_to_exceed <= 365 else 2
            else:
                raise ValueError(f"Unknown task: {task}")

        split_stratum = f"eligible_y{int(y)}" if eligible else "not_eligible"

        rows.append({
            "patient_id": pid,
            "num_psa": rec["num_psa"],
            "eligible": eligible,
            "y": int(y),
            "label": int(label),
            "split_stratum": split_stratum,
        })

    return pd.DataFrame(rows)


def safe_train_test_split(pids, groups, test_size, seed):
    pids = np.asarray(pids, dtype=object)

    if len(pids) < 2:
        return pids, np.array([], dtype=object)

    if groups is not None:
        try:
            return train_test_split(
                pids,
                test_size=test_size,
                random_state=seed,
                stratify=groups,
            )
        except ValueError:
            pass

    return train_test_split(
        pids,
        test_size=test_size,
        random_state=seed,
        stratify=None,
    )


def split_round_patients_kfold(
    round_df,
    seed,
    n_splits=N_SPLITS,
    test_ratio=TEST_RATIO,
):
    if len(round_df) == 0:
        return np.array([], dtype=object), []

    pids = round_df["patient_id"].to_numpy(dtype=object)

    groups = None
    if STRATIFY_PATIENT_SPLIT:
        gv = round_df["split_stratum"].astype(str).to_numpy()
        counts = pd.Series(gv).value_counts()
        if counts.min() >= 2 and len(counts) > 1:
            groups = gv

    trainval_pids, test_pids = safe_train_test_split(
        pids=pids,
        groups=groups,
        test_size=test_ratio,
        seed=seed,
    )
    test_pids = np.array(test_pids, dtype=object)

    trainval_df = round_df[round_df["patient_id"].isin(trainval_pids)].copy()
    trainval_pids_arr = trainval_df["patient_id"].to_numpy(dtype=object)

    if len(trainval_pids_arr) < n_splits:
        if len(trainval_pids_arr) < 2:
            return test_pids, [(trainval_pids_arr, np.array([], dtype=object))]

        train_p, val_p = safe_train_test_split(
            pids=trainval_pids_arr,
            groups=None,
            test_size=1.0 / n_splits,
            seed=seed,
        )
        return test_pids, [(np.array(train_p, dtype=object), np.array(val_p, dtype=object))]

    use_strat = False
    if STRATIFY_PATIENT_SPLIT:
        tv_groups = trainval_df["split_stratum"].astype(str).to_numpy()
        gcounts = pd.Series(tv_groups).value_counts()
        if (gcounts.min() >= n_splits) and (len(gcounts) > 1):
            use_strat = True

    if use_strat:
        skf = StratifiedKFold(n_splits=n_splits, shuffle=True, random_state=seed)
        split_iter = skf.split(trainval_pids_arr, tv_groups)
    else:
        kf = KFold(n_splits=n_splits, shuffle=True, random_state=seed)
        split_iter = kf.split(trainval_pids_arr)

    folds = []
    for tr_idx, val_idx in split_iter:
        folds.append((
            np.array(trainval_pids_arr[tr_idx], dtype=object),
            np.array(trainval_pids_arr[val_idx], dtype=object),
        ))

    return test_pids, folds


def verify_no_patient_leakage(test_pids, folds):
    test_set = set(test_pids.tolist())
    report = {
        "n_test": len(test_set),
        "n_folds": len(folds),
        "fold_sizes": [],
        "test_overlaps_trainval_per_fold": [],
        "train_val_overlaps_per_fold": [],
        "all_ok": True,
    }

    for i, (tr, va) in enumerate(folds):
        tr_set = set(tr.tolist())
        va_set = set(va.tolist())

        report["fold_sizes"].append({
            "fold": i,
            "n_train": len(tr_set),
            "n_val": len(va_set),
        })

        overlap_test_tr = len(test_set & tr_set)
        overlap_test_va = len(test_set & va_set)
        overlap_tr_va = len(tr_set & va_set)

        report["test_overlaps_trainval_per_fold"].append({
            "fold": i,
            "test_train_overlap": overlap_test_tr,
            "test_val_overlap": overlap_test_va,
        })
        report["train_val_overlaps_per_fold"].append({
            "fold": i,
            "train_val_overlap": overlap_tr_va,
        })

        if overlap_test_tr or overlap_test_va or overlap_tr_va:
            report["all_ok"] = False

    if not report["all_ok"]:
        raise RuntimeError(f"Patient-level leakage detected: {report}")

    return report


def summarize_round_audit_kfold(
    round_df,
    test_pids,
    folds,
    raw_patient_count,
    n,
    cutoff,
    task,
):
    eligible_df = round_df[round_df["eligible"]].copy()

    global_summary: Dict[str, Any] = {
        "n": int(n),
        "cutoff": float(cutoff),
        "task": task,
        "raw_patients": int(raw_patient_count),
        "patients_with_min_len": int(len(round_df)),
        "eligible_patients": int(len(eligible_df)),
        "test_ratio": float(TEST_RATIO),
        "n_splits": int(N_SPLITS),
        "approx_train_ratio": float(TRAIN_RATIO),
        "approx_val_ratio": float(VAL_RATIO),
    }

    if task in ["next_psa", "cancer"]:
        pos = int((eligible_df["y"] == 1).sum())
        neg = int((eligible_df["y"] == 0).sum())
        prev = pos / (pos + neg) if (pos + neg) > 0 else 0.0
        global_summary.update({"positive": pos, "negative": neg, "prevalence": float(prev)})
    else:
        for cls in [0, 1, 2]:
            global_summary[f"class_{cls}"] = int((eligible_df["y"] == cls).sum())

    def _split_stats(name, ids):
        sub = round_df[round_df["patient_id"].isin(ids)].copy()
        elig_sub = sub[sub["eligible"]].copy()

        row: Dict[str, Any] = {
            "split": name,
            "patients_with_min_len": int(len(sub)),
            "eligible_patients": int(len(elig_sub)),
        }

        if task in ["next_psa", "cancer"]:
            pos = int((elig_sub["y"] == 1).sum())
            neg = int((elig_sub["y"] == 0).sum())
            prev = pos / (pos + neg) if (pos + neg) > 0 else 0.0
            row.update({"positive": pos, "negative": neg, "prevalence": float(prev)})
        else:
            for cls in [0, 1, 2]:
                row[f"class_{cls}"] = int((elig_sub["y"] == cls).sum())

        return row

    split_rows = [_split_stats("test", set(test_pids.tolist()))]
    for i, (tr, va) in enumerate(folds):
        split_rows.append(_split_stats(f"fold{i}_train", set(tr.tolist())))
        split_rows.append(_split_stats(f"fold{i}_val", set(va.tolist())))

    return {"global": global_summary, "splits": split_rows}


def print_round_audit(audit_summary, n, cutoff, task):
    g = audit_summary["global"]
    split_rows = audit_summary["splits"]
    cutoff_s = f"{cutoff:.1f}"
    min_len = min_required_for_task(task, n)

    print("\n" + "=" * 64)
    print(f"Global Audit  (N = {n}, PSA cutoff = {cutoff_s})")
    print("=" * 64)
    print(f"Patients in raw data                         : {g['raw_patients']:,}")
    print(f"Patients with >= {min_len} PSA measurements        : {g['patients_with_min_len']:,}")
    print(f"Patients eligible, first {n} all < {cutoff_s}      : {g['eligible_patients']:,}")
    print(
        f"K-fold setup: test_ratio={g['test_ratio']:.2f}, "
        f"n_splits={g['n_splits']} => approx train/val/test = "
        f"{g['approx_train_ratio']:.2f}/{g['approx_val_ratio']:.2f}/{g['test_ratio']:.2f}"
    )

    if task == "next_psa":
        print(f"  Positive ({ordinal(n + 1)} PSA >= {cutoff_s}) : {g['positive']:,}")
        print(f"  Negative ({ordinal(n + 1)} PSA <  {cutoff_s}) : {g['negative']:,}")
        print(f"  Global prevalence                   : {g['prevalence']:.4f}")
    elif task == "cancer":
        print(f"  Positive, label = 1                 : {g['positive']:,}")
        print(f"  Negative, label = 0                 : {g['negative']:,}")
        print(f"  Global prevalence                   : {g['prevalence']:.4f}")
    else:
        print(f"  Class 0, never crosses              : {g['class_0']:,}")
        print(f"  Class 1, crosses within 12 months   : {g['class_1']:,}")
        print(f"  Class 2, crosses after 12 months    : {g['class_2']:,}")

    print("\n" + "=" * 64)
    print(f"Per-Split Audit  (seed={RANDOM_SEED}, K={g['n_splits']})")
    print("=" * 64)
    print(pd.DataFrame(split_rows).to_string(index=False))


