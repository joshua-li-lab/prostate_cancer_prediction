def attention_long_df(
    attention_weights: np.ndarray,
    meta: pd.DataFrame,
    y_true: np.ndarray,
    y_pred: Optional[np.ndarray],
    proba: Optional[np.ndarray],
    class_names: List[str],
) -> pd.DataFrame:
    attn = np.asarray(attention_weights)
    if attn.ndim == 3:
        attn = attn.squeeze(-1)

    rows = []
    meta = meta.reset_index(drop=True)

    for i in range(attn.shape[0]):
        base = {
            "sample_index": int(i),
            "patient_id": meta.loc[i, "patient_id"] if "patient_id" in meta.columns else i,
            "y_true": int(y_true[i]),
        }

        if y_pred is not None:
            base["y_pred"] = int(y_pred[i])

        if proba is not None:
            p = np.asarray(proba)
            if p.ndim == 1:
                base["p_event"] = float(p[i])
            elif p.ndim == 2:
                for k in range(p.shape[1]):
                    cname = _class_col_name(class_names[k] if k < len(class_names) else f"class{k}")
                    base[f"p_{cname}"] = float(p[i, k])

        for t in range(attn.shape[1]):
            row = base.copy()
            row["time_step"] = int(t)
            row["attention_weight"] = float(attn[i, t])
            rows.append(row)

    return pd.DataFrame(rows)


def attention_summary_tables(
    attention_weights: np.ndarray,
    y_true: np.ndarray,
    y_pred: Optional[np.ndarray],
    class_names: List[str],
) -> Dict[str, pd.DataFrame]:
    attn = np.asarray(attention_weights)
    if attn.ndim == 3:
        attn = attn.squeeze(-1)

    y_true = np.asarray(y_true, dtype=int)
    summaries = {}

    def _summarize(group_values, group_label_map, group_col):
        rows = []
        for gv in sorted(np.unique(group_values), key=lambda x: str(x)):
            mask = group_values == gv
            mat = attn[mask]
            if len(mat) == 0:
                continue

            for t in range(mat.shape[1]):
                vals = mat[:, t]
                mean_v = float(np.mean(vals))
                std_v = float(np.std(vals, ddof=1)) if len(vals) > 1 else 0.0
                se_v = std_v / math.sqrt(len(vals)) if len(vals) > 0 else np.nan
                ci = 1.96 * se_v if np.isfinite(se_v) else np.nan

                rows.append({
                    group_col: gv,
                    "group_label": group_label_map.get(gv, str(gv)),
                    "time_step": int(t),
                    "n_samples": int(len(vals)),
                    "mean_attention": mean_v,
                    "std_attention": std_v,
                    "ci95_low": mean_v - ci if np.isfinite(ci) else np.nan,
                    "ci95_high": mean_v + ci if np.isfinite(ci) else np.nan,
                })

        return pd.DataFrame(rows)

    true_map = {
        k: class_names[k] if k < len(class_names) else f"Class {k}"
        for k in np.unique(y_true)
    }
    summaries["attention_summary_by_true_class"] = _summarize(
        y_true,
        true_map,
        "true_class",
    )

    if y_pred is not None:
        y_pred = np.asarray(y_pred, dtype=int)
        pred_map = {
            k: class_names[k] if k < len(class_names) else f"Class {k}"
            for k in np.unique(y_pred)
        }
        summaries["attention_summary_by_predicted_class"] = _summarize(
            y_pred,
            pred_map,
            "predicted_class",
        )

        correctness = np.where(y_pred == y_true, "Correct", "Incorrect")
        summaries["attention_summary_by_correctness"] = _summarize(
            correctness,
            {"Correct": "Correct Predictions", "Incorrect": "Incorrect Predictions"},
            "correctness",
        )

    return summaries


