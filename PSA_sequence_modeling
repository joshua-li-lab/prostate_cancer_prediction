    h = history_dict
    candidates = [
        ("loss", "val_loss", "Loss"),
        ("accuracy", "val_accuracy", "Accuracy"),
        ("auc", "val_auc", "AUROC"),
    ]
    panels = [(a, b, c) for a, b, c in candidates if a in h or b in h]

    if not panels:
        return pd.DataFrame()

    fig, axes = plt.subplots(
        1,
        len(panels),
        figsize=(5.2 * len(panels), 4.2),
        constrained_layout=True,
    )
    axes = _prepare_axes_array(axes)

    rows = []

    for ax, (train_key, val_key, ylabel) in zip(axes, panels):
        if train_key in h:
            xs = np.arange(1, len(h[train_key]) + 1)
            ax.plot(xs, h[train_key], label=f"Training {ylabel}", color=PLOT_PALETTE["primary"])
