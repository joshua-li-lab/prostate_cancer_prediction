def plot_attention_examples(
    attn_model,
    X_scaled,
    save_path,
    title,
    risk_scores: np.ndarray,
    meta: Optional[pd.DataFrame] = None,
    y_true: Optional[np.ndarray] = None,
    y_pred: Optional[np.ndarray] = None,
    proba: Optional[np.ndarray] = None,
    class_names: Optional[List[str]] = None,
):
    if attn_model is None or len(X_scaled) < 2:
        return pd.DataFrame()

    class_names = class_names or []
    risk = np.asarray(risk_scores, dtype=float).ravel()

    n_examples = min(6, len(X_scaled) // 2)
    if n_examples < 1:
        return pd.DataFrame()

    high_idx = np.argsort(risk)[-n_examples:][::-1]
    low_idx = np.argsort(risk)[:n_examples]

    a_high = predict_model(attn_model, X_scaled[high_idx]).squeeze(-1)
    a_low = predict_model(attn_model, X_scaled[low_idx]).squeeze(-1)

    combined = np.concatenate([a_high.ravel(), a_low.ravel()])
    vmax = float(np.quantile(combined, 0.95)) if len(combined) else None
    if vmax is not None and vmax <= 0:
        vmax = None

    fig, axes = plt.subplots(2, 1, figsize=(13, 7.2), constrained_layout=True)
    rows = []

    for ax, mat, idxs, ylabel, group in zip(
        axes,
        [a_high, a_low],
        [high_idx, low_idx],
        ["High Predicted Risk Samples", "Low Predicted Risk Samples"],
        ["high", "low"],
    ):
        im = ax.imshow(
            mat,
            aspect="auto",
            cmap=ATTENTION_CMAP,
            vmin=0,
            vmax=vmax,
            interpolation="nearest",
        )

        ax.set_xlabel("Sequence Position")
        ax.set_ylabel(ylabel)
