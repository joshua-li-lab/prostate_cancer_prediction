def class_counts_ok(y, num_classes):
    if len(y) == 0:
        return False

    vals, counts = np.unique(y, return_counts=True)

    if len(vals) < num_classes:
        return False

    return bool(np.min(counts) >= MIN_CLASS_COUNT_TO_TRAIN)


def _summarize_fold_metric_list(values):
    arr = np.array([
        v for v in values
        if v is not None and isinstance(v, (int, float, np.integer, np.floating))
        and np.isfinite(v)
    ])

    if len(arr) == 0:
        return {"mean": float("nan"), "std": float("nan")}

    return {
        "mean": float(np.mean(arr)),
        "std": float(np.std(arr, ddof=1) if len(arr) > 1 else 0.0),
    }


def safe_nanargmax(values):
    arr = np.asarray(values, dtype=float)

    if len(arr) == 0 or not np.isfinite(arr).any():
        return 0

    return int(np.nanargmax(arr))


def _fmt_metric(v):
    if isinstance(v, (int, float, np.integer, np.floating)) and np.isfinite(v):
        return f"{float(v):.3f}"
    return "NA"


