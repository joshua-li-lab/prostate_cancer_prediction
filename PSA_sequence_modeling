def permutation_importance_binary(
    model,
    X_test_scaled,
    y_test,
    feature_names,
    n_repeats,
    seed,
):
    if len(np.unique(y_test)) < 2:
        return pd.DataFrame()

    rng = np.random.RandomState(seed)

    p_base = predict_model(model, X_test_scaled).ravel()
    base_auroc = roc_auc_score(y_test, p_base)

    rows = []

    for j, name in enumerate(feature_names):
        auroc_scores = []

        for _ in range(n_repeats):
            X_perm = X_test_scaled.copy()
            perm_idx = rng.permutation(len(X_perm))
            X_perm[:, :, j] = X_perm[perm_idx, :, j]

            p_perm = predict_model(model, X_perm).ravel()
            auroc_scores.append(roc_auc_score(y_test, p_perm))

        rows.append({
            "feature": name,
            "base_auroc": float(base_auroc),
            "permuted_auroc": float(np.mean(auroc_scores)),
            "auroc_drop": float(base_auroc - np.mean(auroc_scores)),
            "n_repeats": int(n_repeats),
            "importance_type": "raw_model_permutation",
        })

    return pd.DataFrame(rows).sort_values("auroc_drop", ascending=False)


def permutation_importance_multiclass(
    model,
    X_test_scaled,
    y_test,
    feature_names,
    num_classes,
    n_repeats,
    seed,
):
    if len(np.unique(y_test)) < 2:
        return pd.DataFrame()

    rng = np.random.RandomState(seed)

    p_base = predict_model(model, X_test_scaled)
    y_base = np.argmax(p_base, axis=1)

    base_m = multiclass_clinical_metrics(
        y_true=y_test,
        y_pred=y_base,
        y_proba=p_base,
        num_classes=num_classes,
    )

    base_auroc = base_m.get("auroc_macro", np.nan)
    base_brier = base_m.get("brier_multiclass_normalized", np.nan)

    rows = []

    for j, name in enumerate(feature_names):
        auroc_scores = []
        brier_scores = []

        for _ in range(n_repeats):
            X_perm = X_test_scaled.copy()
            perm_idx = rng.permutation(len(X_perm))
            X_perm[:, :, j] = X_perm[perm_idx, :, j]

            p_perm = predict_model(model, X_perm)
            y_perm = np.argmax(p_perm, axis=1)

            m_perm = multiclass_clinical_metrics(
                y_true=y_test,
                y_pred=y_perm,
                y_proba=p_perm,
                num_classes=num_classes,
            )

            auroc_scores.append(m_perm.get("auroc_macro", np.nan))
            brier_scores.append(m_perm.get("brier_multiclass_normalized", np.nan))

        mean_auroc = float(np.nanmean(auroc_scores))
        mean_brier = float(np.nanmean(brier_scores))

        rows.append({
            "feature": name,
            "base_auroc_macro": float(base_auroc),
            "permuted_auroc_macro": mean_auroc,
            "auroc_macro_drop": float(base_auroc - mean_auroc) if np.isfinite(base_auroc) else np.nan,
            "base_brier_multiclass_normalized": float(base_brier),
            "permuted_brier_multiclass_normalized": mean_brier,
            "brier_increase": float(mean_brier - base_brier) if np.isfinite(base_brier) else np.nan,
            "n_repeats": int(n_repeats),
            "importance_type": "raw_model_permutation",
        })

    return pd.DataFrame(rows).sort_values("auroc_macro_drop", ascending=False)


