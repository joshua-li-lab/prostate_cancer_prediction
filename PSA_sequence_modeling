        f"Sens={_fmt_metric(m['sensitivity_recall'])}, "
        f"Spec={_fmt_metric(m['specificity'])}, "
        f"PPV={_fmt_metric(m['precision_ppv'])}, "
        f"NPV={_fmt_metric(m['npv'])}"
