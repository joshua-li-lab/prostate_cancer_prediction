    print(
        f"    TP={m['tp']}, FP={m['fp']}, TN={m['tn']}, FN={m['fn']}, "
        f"Prevalence={_fmt_metric(m['prevalence'])}"
    )


def _print_binary_metrics_with_ci(title, m, boot, extra=""):
    print(f"  [{title}]{(' ' + extra) if extra else ''}")

    def _f(k):
        if k in boot and np.isfinite(boot[k][0]):
            _, lo, hi = boot[k]
            return f"{_fmt_metric(m[k])} (95% CI {lo:.3f}-{hi:.3f})"
        return _fmt_metric(m[k])

    for key, label in [
        ("accuracy", "Acc"),
        ("sensitivity_recall", "Sens"),
        ("specificity", "Spec"),
        ("precision_ppv", "PPV"),
        ("npv", "NPV"),
        ("f1", "F1"),
        ("auroc", "AUROC"),
        ("brier", "Brier"),
    ]:
        print(f"    {label:<10s}= {_f(key)}")

    print(
        f"    TP={m['tp']}, FP={m['fp']}, TN={m['tn']}, FN={m['fn']}, "
        f"Prevalence={_fmt_metric(m['prevalence'])}"
    )


