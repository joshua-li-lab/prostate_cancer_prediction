def run_experiment(
    patient_cache,
    patient_lookup,
    raw_patient_count,
    n,
    cutoff,
    task,
    exp_dir,
    num_classes,
    class_names,
):
    print(f"\n\nStarting round: {task_display_name(task)}, N = {n}, PSA cutoff = {cutoff}")

    run_dir = os.path.join(exp_dir, f"n{n}_cutoff{cutoff}")
    os.makedirs(run_dir, exist_ok=True)

    round_seed = stable_seed(task, n, cutoff, "round", base_seed=RANDOM_SEED)

    round_df = compute_round_patient_table(
        patient_cache=patient_cache,
        n=n,
        cutoff=cutoff,
        task=task,
    )

    test_pids, folds = split_round_patients_kfold(
        round_df=round_df,
        seed=round_seed,
        n_splits=N_SPLITS,
        test_ratio=TEST_RATIO,
    )

    split_assignment_df = make_split_assignment_df(test_pids, folds)
    split_assignment_df.to_csv(
        os.path.join(run_dir, f"split_assignments_{task}_n{n}_c{cutoff}.csv"),
        index=False,
    )

    round_df.to_csv(
        os.path.join(run_dir, f"round_patient_table_{task}_n{n}_c{cutoff}.csv"),
        index=False,
    )

    leakage_report = verify_no_patient_leakage(test_pids, folds)
    save_json(
        leakage_report,
        os.path.join(run_dir, f"leakage_check_{task}_n{n}_c{cutoff}.json"),
    )

    audit_summary = summarize_round_audit_kfold(
        round_df=round_df,
        test_pids=test_pids,
        folds=folds,
        raw_patient_count=raw_patient_count,
        n=n,
        cutoff=cutoff,
        task=task,
    )

    print_round_audit(audit_summary, n, cutoff, task)

    save_json(
        audit_summary,
        os.path.join(run_dir, f"audit_{task}_n{n}_c{cutoff}.json"),
    )

    pd.DataFrame(audit_summary["splits"]).to_csv(
        os.path.join(run_dir, f"audit_splits_{task}_n{n}_c{cutoff}.csv"),
        index=False,
    )

    if audit_summary["global"]["eligible_patients"] == 0:
        print("  [skip] No eligible patients.")
        return None

    sequence_bank = build_sequence_bank(
        patient_cache=patient_cache,
        round_df=round_df,
        n=n,
        cutoff=cutoff,
        task=task,
        patient_lookup=patient_lookup,
    )

    test_seq = subset_sequence_bank(sequence_bank, test_pids)

    if test_seq is None:
        print("  [skip] No eligible sequences in test set.")
        return None

    X_test, y_test, pids_test, labels_test, meta_test, feature_names = test_seq

    if num_classes == 2 and len(np.unique(y_test)) < 2:
        print("  [skip] Test set has only one class.")
        return None

    fold_histories: List[Dict[str, List[float]]] = []
    fold_test_probs: List[np.ndarray] = []
    fold_test_probs_cal: List[np.ndarray] = []
    fold_val_thresholds: List[float] = []
    fold_val_thresholds_ovr: List[np.ndarray] = []
    fold_metrics_records: List[Dict[str, float]] = []
    fold_ids_used: List[int] = []
    fold_val_scores: List[float] = []
    fold_artifacts: List[Dict[str, Any]] = []
    fold_val_prediction_frames: List[pd.DataFrame] = []
    fold_test_prediction_frames: List[pd.DataFrame] = []
    fold_calibration_infos: List[Dict[str, Any]] = []

    print(f"  Test sequence count: {len(y_test):,}")
    print(f"  Test class counts: {dict(zip(*np.unique(y_test, return_counts=True)))}")

    need_posthoc_model = PLOT_ATTENTION or RUN_FEATURE_IMPORTANCE

    for fold_idx, (train_pids, val_pids) in enumerate(folds):
        print(f"\n  ---- Fold {fold_idx + 1}/{len(folds)} ----")
        fold_seed = stable_seed(task, n, cutoff, "fold", fold_idx, base_seed=RANDOM_SEED)
        set_global_seed(fold_seed)

        train_seq = subset_sequence_bank(sequence_bank, train_pids)
        val_seq = subset_sequence_bank(sequence_bank, val_pids)

        if train_seq is None or val_seq is None:
            print(f"  [skip fold {fold_idx}] Empty train or validation sequences.")
            continue

        X_tr, y_tr, pids_tr, labels_tr, meta_tr, _ = train_seq
        X_va, y_va, pids_va, labels_va, meta_va, _ = val_seq

        if not class_counts_ok(y_tr, num_classes):
            print(
                f"  [skip fold {fold_idx}] training class counts too small: "
                f"{dict(zip(*np.unique(y_tr, return_counts=True)))}"
            )
            continue

        if num_classes == 2 and len(np.unique(y_va)) < 2:
            print(f"  [skip fold {fold_idx}] validation has only one class.")
            continue

        scaler = fit_scaler(X_tr)
        X_tr_s = apply_scaler(X_tr, scaler)
        X_va_s = apply_scaler(X_va, scaler)
        X_te_s = apply_scaler(X_test, scaler)

        X_tr_fit, y_tr_fit, class_weight = handle_imbalance_train(
            X_train=X_tr_s,
            y_train=y_tr,
            method=IMBALANCE_METHOD,
            seed=fold_seed,
        )

        print(
            f"    Training rows after imbalance: {len(y_tr_fit):,}, "
            f"Validation rows: {len(y_va):,}, Class weight: {class_weight}"
        )

        tf.keras.backend.clear_session()
        gc.collect()
        set_global_seed(fold_seed)

        model, attn_model = build_model(
            n_timesteps=n,
            n_features=X_tr.shape[-1],
            num_classes=num_classes,
        )

        callbacks = [
            EarlyStopping(
                monitor="val_loss",
                patience=EARLY_STOP_PATIENCE,
                restore_best_weights=True,
            ),
            ReduceLROnPlateau(
                monitor="val_loss",
                factor=0.5,
                patience=LR_REDUCE_PATIENCE,
                min_lr=1e-5,
                verbose=1 if TF_VERBOSE else 0,
            ),
        ]

        history = model.fit(
            X_tr_fit,
            y_tr_fit,
            validation_data=(X_va_s, y_va),
            epochs=EPOCHS,
            batch_size=BATCH_SIZE,
            verbose=TF_VERBOSE,
            callbacks=callbacks,
            class_weight=class_weight,
            shuffle=True,
        )

        fold_histories.append(history.history)

        plot_history(
            history.history,
            os.path.join(run_dir, f"history_{task}_n{n}_c{cutoff}_fold{fold_idx}.png"),
            title=make_plot_title(task, n, cutoff, f"Training History, Fold {fold_idx}"),
        )

        model_path = os.path.join(run_dir, f"model_{task}_n{n}_c{cutoff}_fold{fold_idx}.keras")
        scaler_path = os.path.join(run_dir, f"scaler_{task}_n{n}_c{cutoff}_fold{fold_idx}.pkl")

        try:
            with open(scaler_path, "wb") as f:
                pickle.dump(scaler, f)
        except Exception as e:
            print(f"  [warn] Could not save scaler: {e}")

        if SAVE_MODELS or need_posthoc_model:
            try:
                model.save(model_path)
            except Exception as e:
                print(f"  [warn] Could not save model: {e}")
                model_path = None
        else:
            model_path = None

        if num_classes == 2:
            p_val_raw = predict_model(model, X_va_s).ravel()
            p_test_raw = predict_model(model, X_te_s).ravel()

            p_val_cal, p_test_cal, cal_obj = fit_and_apply_calibration(
                p_val_raw=p_val_raw,
                y_val=y_va,
                p_test_raw=p_test_raw,
                method=CALIBRATION_METHOD,
            )

            thr = choose_threshold(
                y_val=y_va,
                p_val=p_val_cal,
                method="f2",
                task=task,
            )

            y_hat_val = (p_val_cal >= thr).astype(int)
            y_hat_fold = (p_test_cal >= thr).astype(int)

            metrics_fold = binary_clinical_metrics(y_test, y_hat_fold, p_test_cal)

            fold_metrics_records.append(metrics_fold)
            fold_ids_used.append(fold_idx)
            fold_val_thresholds.append(thr)
            fold_test_probs.append(p_test_raw)
            fold_test_probs_cal.append(p_test_cal)

            fold_val_prediction_frames.append(
                make_binary_prediction_frame(
                    meta=meta_va,
                    y_true=y_va,
                    p_raw=p_val_raw,
                    p_cal=p_val_cal,
                    threshold=thr,
                    fold=fold_idx,
                    split="val",
                    y_pred=y_hat_val,
                )
            )

            fold_test_prediction_frames.append(
                make_binary_prediction_frame(
                    meta=meta_test,
                    y_true=y_test,
                    p_raw=p_test_raw,
                    p_cal=p_test_cal,
                    threshold=thr,
                    fold=fold_idx,
                    split="test_per_fold",
                    y_pred=y_hat_fold,
                )
            )

            if cal_obj is not None:
                try:
                    with open(
                        os.path.join(run_dir, f"calibrator_{task}_n{n}_c{cutoff}_fold{fold_idx}.pkl"),
                        "wb",
                    ) as f:
                        pickle.dump(cal_obj, f)
                except Exception as e:
                    print(f"  [warn] Could not save calibrator: {e}")

            try:
                val_score = roc_auc_score(y_va, p_val_cal)
            except Exception:
                val_score = np.nan

            fold_val_scores.append(float(val_score))
            fold_artifacts.append({
                "fold": int(fold_idx),
                "model_path": model_path,
                "scaler_path": scaler_path,
                "val_selection_score": float(val_score) if np.isfinite(val_score) else np.nan,
                "val_selection_metric": "AUROC",
            })

            _print_binary_metrics_block(
                title=f"Fold {fold_idx} Test",
                m=metrics_fold,
                extra=f"threshold={thr:.4f}",
            )

        else:
            p_val_raw = predict_model(model, X_va_s)
            p_test_raw = predict_model(model, X_te_s)

            p_val_cal, p_test_cal, cal_obj, cal_info = fit_and_apply_multiclass_calibration(
                p_val_raw=p_val_raw,
                y_val=y_va,
                p_test_raw=p_test_raw,
                method=CALIBRATION_METHOD,
                num_classes=num_classes,
            )

            cal_info["fold"] = int(fold_idx)
            fold_calibration_infos.append(cal_info)

            thr_ovr = choose_thresholds_ovr(
                y_val=y_va,
                p_val_proba=p_val_cal,
                method="f2",
                num_classes=num_classes,
            )

            y_hat_val = predict_ovr(p_val_cal, thr_ovr)
            y_hat_fold = predict_ovr(p_test_cal, thr_ovr)

            metrics_fold = multiclass_clinical_metrics(
                y_true=y_test,
                y_pred=y_hat_fold,
                y_proba=p_test_cal,
                num_classes=num_classes,
            )

            fold_metrics_records.append(metrics_fold)
            fold_ids_used.append(fold_idx)
            fold_val_thresholds_ovr.append(thr_ovr)
            fold_test_probs.append(p_test_raw)
            fold_test_probs_cal.append(p_test_cal)

            fold_val_prediction_frames.append(
                make_multiclass_prediction_frame(
                    meta=meta_va,
                    y_true=y_va,
                    p_raw=p_val_raw,
                    p_cal=p_val_cal,
                    thresholds=thr_ovr,
                    fold=fold_idx,
                    split="val",
                    class_names=class_names,
                    y_pred=y_hat_val,
                )
            )

            fold_test_prediction_frames.append(
                make_multiclass_prediction_frame(
                    meta=meta_test,
                    y_true=y_test,
                    p_raw=p_test_raw,
                    p_cal=p_test_cal,
                    thresholds=thr_ovr,
                    fold=fold_idx,
                    split="test_per_fold",
                    class_names=class_names,
                    y_pred=y_hat_fold,
                )
            )

            if cal_obj is not None:
                try:
                    with open(
                        os.path.join(run_dir, f"calibrator_{task}_n{n}_c{cutoff}_fold{fold_idx}.pkl"),
                        "wb",
                    ) as f:
                        pickle.dump(cal_obj, f)
                except Exception as e:
                    print(f"  [warn] Could not save multiclass calibrator: {e}")

            try:
                y_bin_v = label_binarize(y_va, classes=list(range(num_classes)))
                val_score = roc_auc_score(
                    y_bin_v,
                    p_val_cal,
                    average="macro",
                    multi_class="ovr",
                )
            except Exception:
                val_score = np.nan

            fold_val_scores.append(float(val_score))
            fold_artifacts.append({
                "fold": int(fold_idx),
                "model_path": model_path,
                "scaler_path": scaler_path,
                "val_selection_score": float(val_score) if np.isfinite(val_score) else np.nan,
                "val_selection_metric": "Macro AUROC",
            })

            _print_multi_metrics_block(
                title=f"Fold {fold_idx} Test",
                m=metrics_fold,
                num_classes=num_classes,
                class_names=class_names,
                extra=f"OvR thresholds={np.round(thr_ovr, 3).tolist()}",
            )

        del model, attn_model, X_tr_s, X_va_s, X_te_s, X_tr_fit, y_tr_fit
        gc.collect()
        tf.keras.backend.clear_session()

    if len(fold_metrics_records) == 0:
        print("  [skip] No usable folds.")
        return None

    result: Dict[str, Any] = {
        "task": task,
        "experiment_name": task_display_name(task),
        "n": int(n),
        "cutoff": float(cutoff),
        "n_splits": int(N_SPLITS),
        "test_ratio": float(TEST_RATIO),
        "imbalance_method": IMBALANCE_METHOD,
        "threshold_method": THRESHOLD_METHOD,
        "audit": audit_summary,
        "feature_names": feature_names,
        "leakage_verification": leakage_report,
        "n_folds_used": int(len(fold_metrics_records)),
        "fold_ids_used": fold_ids_used,
        "fold_metrics": fold_metrics_records,
        "fold_artifacts": fold_artifacts,
    }

    metric_keys = set()
    for m in fold_metrics_records:
        for k, v in m.items():
            if isinstance(v, (int, float, np.integer, np.floating)):
                metric_keys.add(k)

    fold_summary = {}
    for k in metric_keys:
        fold_summary[k] = _summarize_fold_metric_list(
            [m.get(k, np.nan) for m in fold_metrics_records]
        )

    result["fold_metrics_summary"] = fold_summary

    dyn_df = plot_learning_dynamics_kfold(
        histories=fold_histories,
        save_path=os.path.join(run_dir, f"learning_dynamics_kfold_{task}_n{n}_c{cutoff}.png"),
        title=make_plot_title(task, n, cutoff, "K-Fold Learning Dynamics"),
    )

