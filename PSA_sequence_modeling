            ax.set_yticklabels([f"Sample {int(i)}" for i in idxs], fontsize=8)

        for r, original_idx in enumerate(idxs):
            base = {
                "risk_group": group,
                "display_row": int(r),
                "sample_index": int(original_idx),
                "risk_score": float(risk[original_idx]),
