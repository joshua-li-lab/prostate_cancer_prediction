def regenerate_all_plots_under_result_root(result_root: str) -> None:
    root = Path(result_root)

    for run_dir in root.rglob("n*_cutoff*"):
        if run_dir.is_dir() and (run_dir / "plot_data_raw").exists():
            regenerate_plots_for_run(str(run_dir))


