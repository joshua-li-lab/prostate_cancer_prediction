def make_binary_prediction_frame(
    meta: pd.DataFrame,
    y_true: np.ndarray,
    p_raw: Optional[np.ndarray],
    p_cal: Optional[np.ndarray],
    threshold: Optional[float],
    fold: Optional[int],
    split: str,
    y_pred: Optional[np.ndarray] = None,
) -> pd.DataFrame:
    df = meta.copy().reset_index(drop=True)
    df.insert(0, "split", split)
    df.insert(0, "fold", fold if fold is not None else np.nan)

    df["y_true"] = np.asarray(y_true, dtype=int)

    if p_raw is not None:
        df["p_raw"] = np.asarray(p_raw, dtype=float)
    if p_cal is not None:
        df["p_calibrated"] = np.asarray(p_cal, dtype=float)
    if threshold is not None:
        df["threshold"] = float(threshold)
    if y_pred is not None:
        df["y_pred"] = np.asarray(y_pred, dtype=int)

    return df


def make_multiclass_prediction_frame(
    meta: pd.DataFrame,
    y_true: np.ndarray,
    p_raw: Optional[np.ndarray],
    p_cal: Optional[np.ndarray],
    thresholds: Optional[np.ndarray],
    fold: Optional[int],
    split: str,
    class_names: List[str],
    y_pred: Optional[np.ndarray] = None,
) -> pd.DataFrame:
    df = meta.copy().reset_index(drop=True)
    df.insert(0, "split", split)
    df.insert(0, "fold", fold if fold is not None else np.nan)

    df["y_true"] = np.asarray(y_true, dtype=int)

    if y_pred is not None:
        df["y_pred"] = np.asarray(y_pred, dtype=int)

    if p_raw is not None:
        p_raw = np.asarray(p_raw, dtype=float)
        for k in range(p_raw.shape[1]):
            cname = _class_col_name(class_names[k] if k < len(class_names) else f"class{k}")
            df[f"p_raw_{cname}"] = p_raw[:, k]

    if p_cal is not None:
        p_cal = np.asarray(p_cal, dtype=float)
        for k in range(p_cal.shape[1]):
            cname = _class_col_name(class_names[k] if k < len(class_names) else f"class{k}")
            df[f"p_calibrated_{cname}"] = p_cal[:, k]

    if thresholds is not None:
        thresholds = np.asarray(thresholds, dtype=float)
        for k, thr in enumerate(thresholds):
            cname = _class_col_name(class_names[k] if k < len(class_names) else f"class{k}")
            df[f"ovr_threshold_{cname}"] = float(thr)

    return df


def sequence_features_long_df(
    X_unscaled: np.ndarray,
    meta: pd.DataFrame,
    y_true: np.ndarray,
    y_pred: Optional[np.ndarray],
    feature_names: List[str],
    proba: Optional[np.ndarray],
    class_names: List[str],
) -> pd.DataFrame:
    rows = []
    meta = meta.reset_index(drop=True)
    X_unscaled = np.asarray(X_unscaled)

    for i in range(X_unscaled.shape[0]):
        base = {
            "sample_index": int(i),
            "patient_id": meta.loc[i, "patient_id"] if "patient_id" in meta.columns else i,
            "y_true": int(y_true[i]),
        }

        if y_pred is not None:
            base["y_pred"] = int(y_pred[i])

        if proba is not None:
            p = np.asarray(proba)
            if p.ndim == 1:
                base["p_event"] = float(p[i])
            elif p.ndim == 2:
                for k in range(p.shape[1]):
                    cname = _class_col_name(class_names[k] if k < len(class_names) else f"class{k}")
                    base[f"p_{cname}"] = float(p[i, k])

        for t in range(X_unscaled.shape[1]):
            row = base.copy()
            row["time_step"] = int(t)
            for j, fname in enumerate(feature_names):
                row[fname] = float(X_unscaled[i, t, j])
            rows.append(row)

    return pd.DataFrame(rows)


def ci_string(v):
    m, lo, hi = v
    if not np.isfinite(m):
        return "NA"
    return f"{m:.3f} ({lo:.3f}-{hi:.3f})"


def flatten_binary_result(r):
    row = {
        "task": r["task"],
        "experiment_name": task_display_name(r["task"]),
        "n": r["n"],
        "cutoff": r["cutoff"],
        "n_splits": r.get("n_splits", N_SPLITS),
        "imbalance_method": r["imbalance_method"],
        "threshold_method": r["threshold_method"],
        "threshold": r.get("threshold", np.nan),
        "calibration_method": r.get("calibration_method", np.nan),
        "raw_patients": r["audit"]["global"]["raw_patients"],
        "patients_with_min_len": r["audit"]["global"]["patients_with_min_len"],
        "eligible_patients": r["audit"]["global"]["eligible_patients"],
        "global_positive": r["audit"]["global"].get("positive", np.nan),
        "global_negative": r["audit"]["global"].get("negative", np.nan),
        "global_prevalence": r["audit"]["global"].get("prevalence", np.nan),
    }

    for k, v in r.get("metrics_point", {}).items():
        if isinstance(v, (int, float, np.integer, np.floating)):
            row[k] = v

    for k, v in r.get("metrics_boot", {}).items():
        m, lo, hi = v
        row[f"{k}_mean"] = m
        row[f"{k}_ci_lo"] = lo
        row[f"{k}_ci_hi"] = hi
        row[f"{k}_ci"] = ci_string(v)

    for k, v in r.get("calibration", {}).items():
        row[k] = v

    for k, v in r.get("fold_metrics_summary", {}).items():
        row[f"fold_{k}_mean"] = v.get("mean", np.nan)
        row[f"fold_{k}_std"] = v.get("std", np.nan)

    return row


def flatten_multi_result(r):
    row = {
        "task": r["task"],
        "experiment_name": task_display_name(r["task"]),
        "n": r["n"],
        "cutoff": r["cutoff"],
        "n_splits": r.get("n_splits", N_SPLITS),
        "imbalance_method": r["imbalance_method"],
        "threshold_method": r.get("threshold_method", THRESHOLD_METHOD),
        "calibration_method": r.get("calibration_method", np.nan),
        "raw_patients": r["audit"]["global"]["raw_patients"],
        "patients_with_min_len": r["audit"]["global"]["patients_with_min_len"],
        "eligible_patients": r["audit"]["global"]["eligible_patients"],
        "class_0": r["audit"]["global"].get("class_0", np.nan),
        "class_1": r["audit"]["global"].get("class_1", np.nan),
        "class_2": r["audit"]["global"].get("class_2", np.nan),
    }

    for k, v in r.get("metrics_point", {}).items():
        if isinstance(v, (int, float, np.integer, np.floating)):
            row[k] = v

    for k, v in r.get("metrics_boot", {}).items():
        m, lo, hi = v
        row[f"{k}_mean"] = m
        row[f"{k}_ci_lo"] = lo
        row[f"{k}_ci_hi"] = hi
        row[f"{k}_ci"] = ci_string(v)

    if "ovr_thresholds" in r:
        for k, t in enumerate(r["ovr_thresholds"]):
            row[f"ovr_threshold_class{k}"] = float(t)

    for cls_key, cal in r.get("calibration_per_class", {}).items():
        for cal_name, cal_value in cal.items():
            row[f"calibration_{cls_key}_{cal_name}"] = cal_value

    for k, v in r.get("fold_metrics_summary", {}).items():
        row[f"fold_{k}_mean"] = v.get("mean", np.nan)
        row[f"fold_{k}_std"] = v.get("std", np.nan)

    return row


def write_master_workbook(results, out_xlsx, num_classes):
    if num_classes == 2:
        summary = pd.DataFrame([flatten_binary_result(r) for r in results])
    else:
        summary = pd.DataFrame([flatten_multi_result(r) for r in results])

    with pd.ExcelWriter(out_xlsx, engine="openpyxl") as writer:
        summary.to_excel(writer, sheet_name="summary", index=False)

        cm_rows = []
        for r in results:
            if "test_confusion" not in r:
                continue

            cm = np.array(r["test_confusion"])
            row = {
                "task": r["task"],
                "experiment_name": task_display_name(r["task"]),
                "n": r["n"],
                "cutoff": r["cutoff"],
            }

            if num_classes == 2:
                row.update({
                    "TN": int(cm[0, 0]),
                    "FP": int(cm[0, 1]),
                    "FN": int(cm[1, 0]),
                    "TP": int(cm[1, 1]),
                    "threshold": r.get("threshold", np.nan),
                })
            else:
                for i in range(cm.shape[0]):
                    for j in range(cm.shape[1]):
                        row[f"true_{i}_pred_{j}"] = int(cm[i, j])

            cm_rows.append(row)

        if cm_rows:
            pd.DataFrame(cm_rows).to_excel(writer, sheet_name="confusion", index=False)

        fi_rows = []
        for r in results:
            if "feature_importance" in r:
                fi = pd.DataFrame(r["feature_importance"])
                fi["task"] = r["task"]
                fi["experiment_name"] = task_display_name(r["task"])
                fi["n"] = r["n"]
                fi["cutoff"] = r["cutoff"]
                fi_rows.append(fi)

        if fi_rows:
            pd.concat(fi_rows, ignore_index=True).to_excel(
                writer,
                sheet_name="feature_importance",
                index=False,
            )

        leak_rows = []
        for r in results:
            if "leakage_verification" in r:
                lr = r["leakage_verification"]
                leak_rows.append({
                    "task": r["task"],
                    "experiment_name": task_display_name(r["task"]),
                    "n": r["n"],
                    "cutoff": r["cutoff"],
                    "all_ok": lr["all_ok"],
                    "n_test": lr["n_test"],
                    "n_folds": lr["n_folds"],
                })

        if leak_rows:
            pd.DataFrame(leak_rows).to_excel(writer, sheet_name="leakage_check", index=False)

    return summary


