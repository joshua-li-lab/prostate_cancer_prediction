def fit_scaler(X_train):
    n_samples, n_steps, n_features = X_train.shape
    scaler = StandardScaler()
    scaler.fit(X_train.reshape(-1, n_features))
    return scaler


def apply_scaler(X, scaler):
    n_samples, n_steps, n_features = X.shape
    return scaler.transform(X.reshape(-1, n_features)).reshape(
        n_samples,
        n_steps,
        n_features,
    ).astype(np.float32)


def handle_imbalance_train(X_train, y_train, method, seed):
    classes = np.unique(y_train)

    if method == "none":
        return X_train, y_train, None

    if method == "class_weight":
        weights = compute_class_weight(class_weight="balanced", classes=classes, y=y_train)
        class_weight = {
            int(c): float(min(w, MAX_CLASS_WEIGHT))
            for c, w in zip(classes, weights)
        }
        return X_train, y_train, class_weight

    if method == "downsample":
        rng = np.random.RandomState(seed)
        min_count = min(int(np.sum(y_train == c)) for c in classes)
        keep = []

        for c in classes:
            idx = np.where(y_train == c)[0]
            keep.extend(rng.choice(idx, size=min_count, replace=False))

        keep = np.array(keep)
        rng.shuffle(keep)

        return X_train[keep], y_train[keep], None

    raise ValueError(f"Unknown IMBALANCE_METHOD: {method}")


