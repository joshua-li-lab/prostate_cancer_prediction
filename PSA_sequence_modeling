def build_model(n_timesteps, n_features, num_classes, time_feature_index=2):
    inp = Input(shape=(n_timesteps, n_features), name="input_seq")

    time_feat = SelectTimeFeature(
        time_feature_index=time_feature_index,
        name="time_feature",
    )(inp)

    other_feat = RemoveTimeFeature(
        time_feature_index=time_feature_index,
        name="non_time_features",
    )(inp)

    t2v = Time2Vec(kernel_size=T2V_KERNEL_SIZE, name="time2vec")(time_feat)
    embedded = Concatenate(name="concat_features")([other_feat, t2v])
    embedded = LayerNormalization(name="layer_norm")(embedded)

    attn_alpha = None

    if USE_ATTENTION:
        h = LSTM(
            LSTM_UNITS,
            return_sequences=True,
            dropout=DROPOUT_RATE,
            recurrent_dropout=0.0,
            kernel_regularizer=l2(L2_REG),
            name="lstm",
        )(embedded)

        context, attn_alpha = AttentionPool(name="attention")(h)
        z = Dropout(DROPOUT_RATE, name="dropout_after_attention")(context)

    else:
        z = LSTM(
            LSTM_UNITS,
            return_sequences=False,
            dropout=DROPOUT_RATE,
            recurrent_dropout=0.0,
            kernel_regularizer=l2(L2_REG),
            name="lstm",
        )(embedded)

        z = Dropout(DROPOUT_RATE, name="dropout_after_lstm")(z)

    if num_classes == 2:
        out = Dense(
            1,
            activation="sigmoid",
            kernel_regularizer=l2(L2_REG),
            name="output",
        )(z)

        loss_fn = "binary_crossentropy"
        metrics = [
            "accuracy",
            tf.keras.metrics.AUC(name="auc", curve="ROC"),
        ]

    else:
        out = Dense(
            num_classes,
            activation="softmax",
            kernel_regularizer=l2(L2_REG),
            name="output",
        )(z)

        loss_fn = "sparse_categorical_crossentropy"
        metrics = ["accuracy"]

    model = Model(inputs=inp, outputs=out)
    model.compile(
        optimizer=Adam(learning_rate=LEARNING_RATE, clipnorm=GRADIENT_CLIPNORM),
        loss=loss_fn,
        metrics=metrics,
    )

    attn_model = None
    if USE_ATTENTION and attn_alpha is not None:
        attn_model = Model(inputs=inp, outputs=attn_alpha)

    return model, attn_model


def predict_model(model: Model, X: np.ndarray) -> np.ndarray:
    return model.predict(X, batch_size=PREDICT_BATCH_SIZE, verbose=0)


def load_saved_model_for_posthoc(model_path: str) -> Model:
    try:
        return tf.keras.models.load_model(model_path, compile=False)
    except Exception:
        return tf.keras.models.load_model(model_path, compile=False, safe_mode=False)


def make_attention_extractor(model: Model) -> Optional[Model]:
    if not USE_ATTENTION:
        return None

    try:
        out = model.get_layer("attention").output
        if isinstance(out, (list, tuple)):
            alpha = out[1]
        else:
            return None
        return Model(inputs=model.input, outputs=alpha)
    except Exception:
        return None


